# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ---- Entornos virtuales ----
.venv/
venv/
env/
ENV/

# ---- Cachés de herramientas ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.cache/

# ---- Variables de entorno y secretos ----
.env
.env.*
!.env.example

# ---- Archivos subidos por los usuarios (logos, fotos, adjuntos de gastos) ----
# Se guardan en un volumen, no en el repositorio.
uploads/*
!uploads/.gitkeep

# ---- Base de datos local (si se usa SQLite en desarrollo) ----
*.sqlite3
*.db

# ---- IDE / editores ----
.idea/
.vscode/
*.swp
*~

# ---- Sistema operativo ----
.DS_Store
Thumbs.db
