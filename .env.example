# =============================================================================
#  Variables de entorno del backend (Quesera ERP / Lactis)
#  Copia este archivo como .env y ajusta los valores.  →  cp .env.example .env
#  El archivo .env NO se sube al repositorio (está en .gitignore).
# =============================================================================

# ---- Aplicación ----
PROJECT_NAME=Quesera ERP
VERSION=1.0.0
# development | production   (en production se ocultan detalles y tokens de dev)
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ---- Base de datos (PostgreSQL) ----
# Local (sin Docker), Postgres en el puerto 5433:
DATABASE_URL=postgresql+psycopg2://quesera:quesera@localhost:5433/quesera_erp
# Dentro de Docker Compose el host es el nombre del servicio "db" y el puerto 5432:
# DATABASE_URL=postgresql+psycopg2://quesera:quesera@db:5432/quesera_erp

# ---- Seguridad / JWT ----
# ⚠️ CÁMBIALA en producción por una cadena larga y aleatoria (32+ caracteres).
#    Genera una con:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambiar-en-produccion-por-una-clave-larga-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# Intentos de login fallidos antes de bloquear la cuenta
MAX_LOGIN_ATTEMPTS=5

# ---- CORS (orígenes del frontend permitidos) ----
# Debe ir en formato lista JSON (comillas dobles). Añade el dominio real en producción.
CORS_ORIGINS=["http://localhost:4200","http://localhost:8000","http://localhost:5000"]

# ---- Archivos subidos (logos, fotos, adjuntos de gastos) ----
UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ---- Usuario administrador inicial (se crea en el primer arranque / seed) ----
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=Admin123*
FIRST_ADMIN_EMAIL=admin@quesera.local

# ---- Datos de demostración ----
# true  = siembra empresa demo "Queso La Marginal de la Selva" con proveedores, etc.
# false = solo crea permisos, roles y el superadmin (recomendado en producción).
SEED_DEMO_DATA=true
